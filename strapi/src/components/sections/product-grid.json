{
  "collectionName": "components_sections_product_grids",
  "info": {
    "displayName": "Product Grid",
    "description": "Filterable product grid section"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "default": "Our Products"
    },
    "category_filter": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "limit": {
      "type": "integer",
      "default": 12,
      "min": 1,
      "max": 100
    },
    "show_filters": {
      "type": "boolean",
      "default": true
    },
    "god_mode": {
      "type": "boolean",
      "default": true
    },
    "show_top_stats": {
      "type": "boolean",
      "default": true
    },
    "show_sort": {
      "type": "boolean",
      "default": true
    },
    "show_search": {
      "type": "boolean",
      "default": true
    },
    "show_view_toggle": {
      "type": "boolean",
      "default": true
    },
    "show_wishlist": {
      "type": "boolean",
      "default": true
    },
    "default_sort": {
      "type": "enumeration",
      "enum": ["featured", "price-asc", "price-desc", "top-rated", "newest"],
      "default": "featured"
    },
    "default_view": {
      "type": "enumeration",
      "enum": ["grid", "list"],
      "default": "grid"
    },
    "promo_text": {
      "type": "string",
      "default": "Buy 2 get 1 free on selected drops"
    },
    "promo_cta_text": {
      "type": "string",
      "default": "Grab Deal ->"
    }
  }
}
