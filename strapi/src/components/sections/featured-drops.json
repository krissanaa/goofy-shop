{
  "collectionName": "components_sections_featured_drops",
  "info": {
    "displayName": "Featured Drops",
    "description": "Configurable featured drops section block"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "default": "HYPE DROPS"
    },
    "subtitle": {
      "type": "string",
      "default": "Latest drop picks"
    },
    "limit": {
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 12
    },
    "badge_filter": {
      "type": "enumeration",
      "enum": ["ALL", "NEW", "DROP", "SALE", "HOT", "COLLAB"],
      "default": "DROP"
    },
    "show_timer": {
      "type": "boolean",
      "default": true
    }
  }
}
