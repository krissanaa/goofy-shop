{
  "kind": "singleType",
  "collectionName": "products_pages",
  "info": {
    "singularName": "products-page",
    "pluralName": "products-pages",
    "displayName": "Products Page",
    "description": "Settings for /products page grid and controls"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "seo_title": {
      "type": "string",
      "default": "Products | GOOFY SHOP"
    },
    "seo_description": {
      "type": "text",
      "default": "Browse all products, filter by type, sort, and add to cart."
    },
    "show_marquee": {
      "type": "boolean",
      "default": true
    },
    "show_hero_scene": {
      "type": "boolean",
      "default": true
    },
    "page_title": {
      "type": "string",
      "default": "OUR PRODUCTS"
    },
    "default_category": {
      "type": "string",
      "default": "All"
    },
    "default_sort": {
      "type": "enumeration",
      "enum": [
        "featured",
        "price-asc",
        "price-desc",
        "top-rated",
        "newest"
      ],
      "default": "featured"
    },
    "default_view": {
      "type": "enumeration",
      "enum": ["grid", "list"],
      "default": "grid"
    },
    "initial_favorites_only": {
      "type": "boolean",
      "default": false
    },
    "products_limit": {
      "type": "integer",
      "default": 12,
      "min": 1,
      "max": 100
    },
    "enable_category_tabs": {
      "type": "boolean",
      "default": true
    },
    "enable_sort": {
      "type": "boolean",
      "default": true
    },
    "enable_search": {
      "type": "boolean",
      "default": true
    },
    "enable_view_toggle": {
      "type": "boolean",
      "default": true
    },
    "enable_wishlist": {
      "type": "boolean",
      "default": true
    },
    "enable_top_stats": {
      "type": "boolean",
      "default": true
    },
    "promo_text": {
      "type": "text",
      "default": "Buy 2 get 1 free on selected drops"
    },
    "promo_cta_text": {
      "type": "string",
      "default": "Grab Deal ->"
    }
  }
}
