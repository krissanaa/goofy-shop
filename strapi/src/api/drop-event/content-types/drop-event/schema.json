{
  "kind": "collectionType",
  "collectionName": "drop_events",
  "info": {
    "singularName": "drop-event",
    "pluralName": "drop-events",
    "displayName": "Drop Event",
    "description": "Limited release events and hype countdown entries"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "release_date": {
      "type": "datetime",
      "required": true
    },
    "is_active": {
      "type": "boolean",
      "default": false
    },
    "featured_products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "inversedBy": "drop_events"
    },
    "hero_banner": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
