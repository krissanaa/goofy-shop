{
  "kind": "singleType",
  "collectionName": "locations_pages",
  "info": {
    "singularName": "locations-page",
    "pluralName": "locations-pages",
    "displayName": "Locations Page",
    "description": "Manage the skatepark locations page and menu entry"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "seo_title": {
      "type": "string",
      "default": "Locations | GOOFY SHOP"
    },
    "seo_description": {
      "type": "text",
      "default": "Explore skate parks and open maps directions."
    },
    "menu_enabled": {
      "type": "boolean",
      "default": true
    },
    "menu_label": {
      "type": "string",
      "default": "Location"
    },
    "page_title": {
      "type": "string",
      "default": "Skate Parks"
    },
    "search_placeholder": {
      "type": "string",
      "default": "Search skate parks"
    },
    "parks": {
      "type": "component",
      "repeatable": true,
      "component": "location.park-item"
    }
  }
}
