{
    "collectionName": "components_location_park_items",
    "info": {
        "displayName": "Park Item",
        "description": "A single skatepark entry for the locations page"
    },
    "options": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "address": {
            "type": "string",
            "required": true
        },
        "place_code": {
            "type": "string"
        },
        "category_label": {
            "type": "string",
            "default": "Skatepark"
        },
        "review_snippet": {
            "type": "text"
        },
        "rating": {
            "type": "decimal",
            "default": 4.5,
            "min": 0,
            "max": 5
        },
        "reviews_count": {
            "type": "integer",
            "default": 0,
            "min": 0
        },
        "status": {
            "type": "enumeration",
            "enum": ["open", "closed"],
            "default": "open"
        },
        "opens_text": {
            "type": "string",
            "default": "Opens 4 PM"
        },
        "access_type": {
            "type": "enumeration",
            "enum": ["free", "paid"],
            "default": "free"
        },
        "environment_type": {
            "type": "enumeration",
            "enum": ["indoor", "outdoor"],
            "default": "outdoor"
        },
        "has_bowl": {
            "type": "boolean",
            "default": false
        },
        "has_street": {
            "type": "boolean",
            "default": false
        },
        "has_night": {
            "type": "boolean",
            "default": false
        },
        "tags": {
            "type": "json"
        },
        "distance": {
            "type": "string",
            "default": ""
        },
        "photo_count": {
            "type": "integer",
            "default": 0,
            "min": 0
        },
        "maps_query": {
            "type": "string"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "allowedTypes": ["images"]
        }
    }
}
