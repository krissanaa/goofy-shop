{
    "collectionName": "components_shared_youtube_link_items",
    "info": {
        "displayName": "YouTube Link Item",
        "description": "Single YouTube card entry for homepage section"
    },
    "options": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "label": {
            "type": "string",
            "default": "YOUTUBE"
        },
        "date": {
            "type": "date"
        },
        "duration": {
            "type": "string"
        },
        "color_name": {
            "type": "string",
            "default": "red"
        },
        "color_code": {
            "type": "string"
        },
        "url": {
            "type": "string",
            "required": true
        },
        "thumbnail": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ]
        }
    }
}
