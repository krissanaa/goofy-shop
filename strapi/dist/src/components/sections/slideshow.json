{
    "collectionName": "components_sections_slideshows",
    "info": {
        "displayName": "Slideshow",
        "description": "Homepage hero slideshow with admin-managed images"
    },
    "options": {},
    "attributes": {
        "slides": {
            "type": "media",
            "multiple": true,
            "allowedTypes": ["images"]
        },
        "autoplay_seconds": {
            "type": "integer",
            "default": 6,
            "min": 2,
            "max": 20
        },
        "show_dots": {
            "type": "boolean",
            "default": true
        },
        "show_overlay_text": {
            "type": "boolean",
            "default": true
        },
        "show_buttons": {
            "type": "boolean",
            "default": true
        },
        "show_stats": {
            "type": "boolean",
            "default": true
        },
        "badge_text": {
            "type": "string",
            "default": "SS26 Collection"
        },
        "heading_line_1": {
            "type": "string",
            "default": "BUILT FOR THE"
        },
        "heading_highlight": {
            "type": "string",
            "default": "STREETS."
        },
        "heading_line_2": {
            "type": "string",
            "default": "WORN BY THE CULTURE."
        },
        "description": {
            "type": "text",
            "default": "Premium skate hardware and streetwear essentials. Limited drops, exclusive collabs, zero compromises."
        },
        "primary_cta_text": {
            "type": "string",
            "default": "Shop the Drop"
        },
        "primary_cta_link": {
            "type": "string",
            "default": "/drop"
        },
        "secondary_cta_text": {
            "type": "string",
            "default": "Explore Collection"
        },
        "secondary_cta_link": {
            "type": "string",
            "default": "#products"
        },
        "bottom_note_text": {
            "type": "string",
            "default": "GOOFY SKATE COMMUNITY LAOS"
        },
        "stats": {
            "type": "json",
            "default": [
                { "value": "500+", "label": "Products", "color": "#e52521" },
                { "value": "12K+", "label": "Skaters", "color": "#049cd8" },
                { "value": "100%", "label": "Authentic", "color": "#43b047" }
            ]
        }
    }
}
